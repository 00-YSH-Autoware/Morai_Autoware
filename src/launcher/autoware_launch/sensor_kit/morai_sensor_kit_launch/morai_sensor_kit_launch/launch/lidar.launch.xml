<?xml version="1.0" encoding="UTF-8"?>
<!-- MORAI /lidar/points 를 전처리 체인에 넣고 concatenated 로 내보내는 런치 -->
<launch>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="vehicle_mirror_param_file"/>
  <arg name="input_pointcloud" default="/lidar/points" description="MORAI raw pointcloud topic"/>

  <group>
    <push-ros-namespace namespace="lidar"/>

    <!-- MORAI raw /lidar/points(PointXYZI) -> PointXYZIRC 로 변환해 전처리 체인 입력으로.
         최신 crop box 는 XYZIRC 만 받으므로 XYZI 면 abort 한다. -->
    <node pkg="morai_sensor_kit_launch" exec="pointcloud_xyzi_to_xyzirc.py" name="pointcloud_xyzi_to_xyzirc" output="both">
      <param name="input_topic" value="$(var input_pointcloud)"/>
      <param name="output_topic" value="/sensing/lidar/top/pointcloud_before_sync"/>
    </node>

    <!-- self/mirror crop -> /sensing/lidar/concatenated/pointcloud -->
    <include file="$(find-pkg-share morai_sensor_kit_launch)/launch/pointcloud_preprocessor.launch.py">
      <arg name="use_intra_process" value="true"/>
      <arg name="use_multithread" value="true"/>
      <arg name="pointcloud_container_name" value="$(var pointcloud_container_name)"/>
      <arg name="vehicle_mirror_param_file" value="$(var vehicle_mirror_param_file)"/>
      <arg name="input_frame" value="base_link"/>
      <arg name="output_frame" value="base_link"/>
    </include>
  </group>
</launch>
